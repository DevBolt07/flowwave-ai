{
  "name": "flowwave-monorepo",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "install:all": "npm install",
    "dev:frontend": "npm run dev -w frontend",
    "dev:backend": "npm run dev -w backend",
    "dev": "npx concurrently --kill-others-on-fail \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build": "npm run build -w frontend",
    "lint": "npm run lint -w frontend",
    "preview": "npm run preview -w frontend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
